{
  "version": "0.2",
  "dictionaryDefinitions": [
    { "name": "cspell-dict", "path": "./.cspell/cspell-dict.txt", "addWords": true },
    { "name": "cspell-mako-keywords", "path": "./.cspell/cspell-mako-keywords.txt", "noSuggest": true }
  ],
  "dictionaries": ["cspell-dict"],
  "files": [
    "src/handwritten/**/*.py",
    "src/codegen/utilities/**/*.py",
    "src/codegen/templates/**/*.mako",
    "tests/**/*.py",
    "examples/**/*.py"
  ],
  "ignorePaths": [
    "src/codegen/metadata/**",
    "src/codegen/properties/**",
    "src/codegen/functions/**",
    "src/codegen/protos/**",
    "generated/**"
  ],
  "overrides": [
    {
      // Mako templates: activate the Python dictionary so Python identifiers in templates aren't flagged.
      "filename": "**/*.mako",
      "dictionaries": ["python", "cspell-mako-keywords"]
    }
  ]
}
